{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:DeleteObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::accomplishment-reports",
        "arn:aws:s3:::accomplishment-reports/*",
        "arn:aws:s3:::progress-photos",
        "arn:aws:s3:::progress-photos/*",
        "arn:aws:s3:::warehouse",
        "arn:aws:s3:::warehouse/*"
      ]
    }
  ]
}
